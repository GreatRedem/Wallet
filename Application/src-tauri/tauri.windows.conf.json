{
    "$schema": "https://schema.tauri.app/config/2",
    "identifier": "io.gwallet.windows",
    "app": {
        "withGlobalTauri": false,
        "windows": [
            {
                "title": "GWallet",
                "decorations": true,
                "maximizable": true,
                "alwaysOnTop": true,
                "fullscreen": false,
                "resizable": true,
                "center": true,
                "height": 640,
                "width": 360
            }
        ],
        "security": {
            "csp": null,
            "capabilities": [
                {
                    "identifier": "main-capability",
                    "windows": [
                        "main"
                    ],
                    "permissions": [
                        "core:app:allow-default-window-icon",
                        "core:window:allow-start-dragging",
                        "core:window:allow-set-size",
                        "core:window:allow-maximize",
                        "core:window:allow-minimize",
                        "core:window:allow-center",
                        "core:window:allow-close",
                        "core:window:allow-hide",
                        "core:window:allow-show",
                        "core:menu:allow-new",
                        "core:tray:allow-new",
                        "store:allow-load",
                        "store:allow-save",
                        "store:allow-get",
                        "store:allow-set",
                        "os:allow-hostname",
                        "os:allow-platform",
                        "os:allow-os-type",
                        "os:allow-version",
                        "os:allow-family",
                        "os:allow-locale",
                        "os:allow-arch"
                    ]
                }
            ]
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/icon.png",
            "icons/icon.ico"
        ]
    }
}
