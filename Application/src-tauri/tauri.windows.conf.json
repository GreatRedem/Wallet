{
    "$schema": "https://schema.tauri.app/config/2",
    "identifier": "io.anonymous.windows",
    "app":
    {
        "windows":
        [
            {
                "title": "Anonymous VPN",
                "decorations": false,
                "maximizable": false,
                "fullscreen": false,
                "resizable": false,
                "center": true,
                "height": 640,
                "width": 360
            }
        ],
        "security":
        {
            "csp": null,
            "capabilities":
            [
                {
                    "identifier": "main-capability",
                    "windows":
                    [
                        "main"
                    ],
                    "permissions":
                    [
                        "core:app:allow-default-window-icon",

                        "core:window:allow-start-dragging",
                        "core:window:allow-minimize",
                        "core:window:allow-close",
                        "core:window:allow-hide",
                        "core:window:allow-show",

                        "core:menu:allow-new",

                        "core:tray:allow-new",

                        "os:allow-hostname",
                        "os:allow-locale"
                    ]
                }
            ]
        }
    },
    "bundle":
    {
        "active": true,
        "targets": "all",
        "icon":
        [
            "icons/icon.png",
            "icons/icon.ico"
        ]
    }
}
